# Copy to .env and fill in real values. .env is gitignored — never commit it.

# Required. Get a key at https://console.groq.com
GROQ_API_KEY=your-groq-api-key-here
LLM_PROVIDER=groq

# Optional: local Postgres override (defaults to the docker-compose instance)
# DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/property_insights

# Optional: LangGraph/LangSmith tracing (https://smith.langchain.com)
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=your-langsmith-key-here
# LANGCHAIN_PROJECT=property-insights-assistant

# Optional: fraction of rag/risk answers the LLM-as-judge samples (default 0.3)
# JUDGE_SAMPLE_RATE=0.3
